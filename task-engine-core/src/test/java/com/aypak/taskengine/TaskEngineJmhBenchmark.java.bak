package com.aypak.taskengine;

import org.openjdk.jmh.annotations.*;
import org.openjdk.jmh.runner.Runner;
import org.openjdk.jmh.runner.RunnerException;
import org.openjdk.jmh.runner.options.Options;
import org.openjdk.jmh.runner.options.OptionsBuilder;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.test.context.junit.jupiter.SpringJUnitConfig;

import java.util.concurrent.TimeUnit;

/**
 * JMH Benchmark for TaskEngine performance testing
 */
@BenchmarkMode(Mode.Throughput)
@OutputTimeUnit(TimeUnit.SECONDS)
@State(Scope.Benchmark)
@Fork(value = 1, warmups = 1)
@Warmup(iterations = 3, time = 10, timeUnit = TimeUnit.SECONDS)
@Measurement(iterations = 5, time = 20, timeUnit = TimeUnit.SECONDS)
@SpringJUnitConfig
@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.NONE)
public class TaskEngineJmhBenchmark {

    private TaskEngine taskEngine;
    
    @Setup(Level.Trial)
    public void setup() {
        // Initialize Spring context and get TaskEngine bean
        // This would be handled by SpringJUnitConfig
    }
    
    @Benchmark
    public void submitComputationalTask() {
        TaskConfig config = TaskConfig.builder()
            .taskType(TaskType.COMPUTATION)
            .priority(TaskPriority.MEDIUM)
            .timeoutMs(5000L)
            .build();
            
        taskEngine.submit("benchmark-task-" + System.nanoTime(), 
            () -> {
                // Simulate computational work
                double result = 0;
                for (int i = 0; i < 1000; i++) {
                    result += Math.sqrt(i) * Math.sin(i);
                }
                return result;
            }, config);
    }
    
    @Benchmark
    public void submitIoBoundTask() {
        TaskConfig config = TaskConfig.builder()
            .taskType(TaskType.IO_BOUND)
            .priority(TaskPriority.MEDIUM)
            .timeoutMs(10000L)
            .build();
            
        taskEngine.submit("benchmark-io-task-" + System.nanoTime(),
            () -> {
                // Simulate I/O work
                try {
                    Thread.sleep(10);
                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                }
                return "io-result";
            }, config);
    }
    
    @Benchmark
    @Threads(100)
    public void concurrentTaskSubmission() {
        submitComputationalTask();
    }
    
    @Benchmark
    @Threads(200)
    public void highConcurrencyTaskSubmission() {
        submitIoBoundTask();
    }
    
    public static void main(String[] args) throws RunnerException {
        Options opt = new OptionsBuilder()
            .include(TaskEngineJmhBenchmark.class.getSimpleName())
            .forks(1)
            .build();
            
        new Runner(opt).run();
    }
}